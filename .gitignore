# ============================================================================
# .gitignore: Weather Forecast Analytical DB Project
# ============================================================================
# This file specifies which files Git should ignore (not version control)

# ============================================================================
# Environment Files (SENSITIVE - Contains Credentials)
# ============================================================================
# NEVER commit .env files containing real credentials!

.env
.env.local
.env.*.local
.env.production

# ============================================================================
# Python
# ============================================================================

# Virtual environments
venv/
env/
ENV/
.venv

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# pytest cache
.pytest_cache/

# Coverage reports
htmlcov/
.coverage
.coverage.*

# ============================================================================
# Node.js / Frontend
# ============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
frontend/dist/

# Vite cache
.vite/

# Development
.DS_Store
.vuepress/dist

# ============================================================================
# IDEs & Editors
# ============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
*.iml
*.iws

# ============================================================================
# Logs
# ============================================================================

logs/
*.log
**/*.log

# ============================================================================
# Database
# ============================================================================

# SQLite
*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.sql.bak

# ============================================================================
# OS Files
# ============================================================================

.DS_Store
Thumbs.db
.Thumbs.db

# ============================================================================
# Docker
# ============================================================================

# Don't commit Docker volumes (local data)
postgres_data/
airflow_data/

# ============================================================================
# Airflow
# ============================================================================

airflow/logs/
airflow/webserver_config.py

# ============================================================================
# Temporary Files
# ============================================================================

*.tmp
*.temp
*.bak
*.backup
*.orig
temp/
tmp/

# ============================================================================
# IDEs Generated Files
# ============================================================================

.project
.pydevproject
.settings/
*.code-workspace

# ============================================================================
# MacOS
# ============================================================================

.AppleDouble
.LSOverride
.localized

# ============================================================================
# Linux
# ============================================================================

.cache
.directory
.Xauthority
.Xdefaults

# ============================================================================
# Project Specific
# ============================================================================

# Exported data files
exports/
generated/

# Configuration backups
*.conf.bak
*.yaml.bak
