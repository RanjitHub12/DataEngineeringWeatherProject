# ============================================================================
# Frontend Environment Configuration (.env.example)
# ============================================================================
# Copy this file to .env.local and configure for your environment
#
# IMPORTANT: All variables prefixed with VITE_ are exposed to the browser.
# Do NOT put any secrets in the frontend environment file.
# ============================================================================

# ============================================================================
# API Configuration
# ============================================================================
# Base URL for FastAPI backend API calls
# 
# Development:
#   http://localhost:8000
#
# Production (Render):
#   https://your-app.onrender.com
#
# Production (Self-hosted):
#   https://api.yourdomain.com

VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Application Configuration
# ============================================================================

VITE_APP_NAME=Weather Forecast Dashboard
VITE_APP_VERSION=1.0.0
