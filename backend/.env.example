# ============================================================================
# Backend + Airflow Environment Configuration (.env.example)
# ============================================================================
# Copy this file to backend/.env and configure for your environment
#
# IMPORTANT:
#   - Never commit .env to version control
#   - This file is used by docker-compose via: --env-file backend/.env
# ============================================================================

# ============================================================================
# PostgreSQL Data Warehouse Configuration
# ============================================================================

POSTGRES_USER=weather_user
POSTGRES_PASSWORD=password123
POSTGRES_DB=weather_dw
POSTGRES_PORT=5434

# Use weather-postgres for Docker; use 127.0.0.1 for local backend runs
POSTGRES_HOST=weather-postgres

# ============================================================================
# PostgreSQL Airflow Backend Configuration
# ============================================================================

AIRFLOW_POSTGRES_USER=airflow_user
AIRFLOW_POSTGRES_PASSWORD=airflow_secure_password_456!
AIRFLOW_POSTGRES_DB=airflow_metadata
AIRFLOW_POSTGRES_PORT=5433
AIRFLOW_POSTGRES_HOST=weather-airflow-postgres

# ============================================================================
# Apache Airflow Configuration
# ============================================================================

AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_SCHEDULER_LOG_LEVEL=INFO
AIRFLOW_WEBSERVER_LOG_LEVEL=INFO

AIRFLOW__WEBSERVER__DEFAULT_USER_USERNAME=airflow
AIRFLOW__WEBSERVER__DEFAULT_USER_PASSWORD=airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ============================================================================
# Backend API Configuration (FastAPI)
# ============================================================================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development

# ============================================================================
# CORS Configuration
# ============================================================================

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================================================
# Data Source Configuration
# ============================================================================

OPENMETEO_API_URL=https://archive-api.open-meteo.com/v1/archive
OPENMETEO_TIMEOUT=30
WEATHER_CITIES=New York,London,Tokyo,New Delhi,Mumbai,Bengaluru,Chennai,Kolkata
ANALYSIS_DAYS=30

# ============================================================================
# Logging Configuration
# ============================================================================

LOG_LEVEL=INFO

# ============================================================================
# Docker Compose Configuration (Optional)
# ============================================================================

COMPOSE_PROJECT_NAME=weather-forecast
